# Public HTTP endpoint of php-api/read.php (deployed on your hosting).
# Used by both the public site (server-side fetch) and the /admin page.
NEXT_PUBLIC_PROJECTS_READ_URL=https://yourdomain.ru/api/read.php

# Public HTTP endpoint of php-api/write.php (deployed on your hosting).
# Only called from /admin; every request must include the admin password,
# which write.php checks against its own config.php ADMIN_PASSWORD constant.
NEXT_PUBLIC_PROJECTS_WRITE_URL=https://yourdomain.ru/api/write.php
